{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@hela/contracts": ["./packages/contracts/src/index.ts"],
      "@hela/contracts/*": ["./packages/contracts/src/*"],
      "@hela/data-access": ["./packages/data-access/src/index.ts"],
      "@hela/data-access/*": ["./packages/data-access/src/*"]
    }
  }
}
