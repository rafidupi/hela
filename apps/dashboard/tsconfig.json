{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "composite": false,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@hela/contracts": ["../../packages/contracts/src/index.ts"],
      "@hela/contracts/*": ["../../packages/contracts/src/*"],
      "@hela/data-access": ["../../packages/data-access/src/index.ts"],
      "@hela/data-access/firebase": ["../../packages/data-access/src/firebase/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
